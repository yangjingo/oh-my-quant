{
  "name": "whyj-quant",
  "version": "2.0.0",
  "type": "module",
  "description": "WhyJ Quant — Interactive AI-powered quantitative analysis terminal",
  "keywords": [
    "quantitative",
    "finance",
    "stock",
    "backtest",
    "factor",
    "risk",
    "cli",
    "terminal",
    "ai",
    "agent"
  ],
  "homepage": "https://github.com/yangjing/oh-my-quant",
  "repository": {
    "type": "git",
    "url": "https://github.com/yangjing/oh-my-quant"
  },
  "license": "MIT",
  "author": "yangjing",
  "main": "dist/index.js",
  "bin": {
    "whyj": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "bun run tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepublishOnly": "bun run build && bun run typecheck"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "date-fns": "^4.1.0",
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "typebox": "^1.1.39",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
