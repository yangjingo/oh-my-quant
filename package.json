{
  "name": "whyj-quant",
  "version": "0.1.0",
  "type": "module",
  "description": "WhyJ Quant — Interactive AI-powered quantitative analysis terminal",
  "keywords": [
    "quantitative",
    "finance",
    "stock",
    "backtest",
    "factor",
    "risk",
    "cli",
    "terminal",
    "ai",
    "agent"
  ],
  "homepage": "https://github.com/yangjing/oh-my-quant",
  "repository": {
    "type": "git",
    "url": "https://github.com/yangjing/oh-my-quant"
  },
  "license": "MIT",
  "author": "yangjing",
  "main": "dist/index.js",
  "bin": {
    "whyj": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "bun run dist/index.js",
    "typecheck": "bun run tsc --noEmit",
    "gen:insights": "bun run scripts/generate-insights.ts",
    "test": "bun test src/",
    "test:watch": "bun test --watch",
    "prepublishOnly": "bun run gen:insights && bun run build && bun run typecheck"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.78.0",
    "typebox": "^1.1.39"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
