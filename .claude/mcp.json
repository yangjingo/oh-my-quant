{
  "mcpServers": {
    "financial-datasets": {
      "transport": "http",
      "url": "https://mcp.financialdatasets.ai/",
      "headers": {
        "X-API-KEY": "${FINANCIAL_DATASETS_KEY}"
      }
    },
    "tushare": {
      "transport": "http",
      "url": "https://api.tushare.pro/mcp/token=${TUSHARE_TOKEN}"
    },
    "llmquant-data": {
      "command": "npx",
      "args": ["-y", "@llmquant/data-mcp"],
      "env": {
        "LLMQUANT_API_KEY": "${LLMQUANT_API_KEY}"
      }
    },
    "web-search-prime": {
      "transport": "http",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp"
    },
    "web-reader": {
      "transport": "http",
      "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp"
    }
  }
}
